{
    "name": "rose",
    "private": true,
    "type": "module",
    "scripts": {
        "predev": "bun run panda",
        "prebuild": "bun run panda",
        "dev": "bun x --bun vite --host 0.0.0.0",
        "dev:http": "ROSE_DEV_HTTPS=0 bun x --bun vite --host 127.0.0.1 --strictPort",
        "build": "bun x --bun vite build && bun scripts/emit-static-shell.mjs",
        "preview": "bun x --bun vite preview --host 0.0.0.0",
        "postinstall": "bun run panda",
        "check": "bun x --bun tsc --noEmit",
        "lint": "bun x --bun biome check src packages vite.config.ts panda.config.ts package.json tsconfig.json biome.json",
        "format": "bun x --bun biome format --write src packages vite.config.ts panda.config.ts package.json tsconfig.json biome.json",
        "panda": "bun x --bun panda codegen && bun x --bun panda cssgen \"src/**/*.{ts,tsx}\" -o src/app/styles/panda.css",
        "test": "bun test",
        "test:bench": "bun test packages/armor-bench/src",
        "bench:d2ap": "bun packages/armor-bench/src/cli.ts",
        "hooks:install": "git config core.hooksPath .githooks",
        "version:bump": "bun scripts/bump-version.ts"
    },
    "dependencies": {
        "@solidjs/router": "^0.15.3",
        "@solidjs/start": "alpha",
        "solid-js": "^1.9.11"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.3.8",
        "@pandacss/dev": "^1.7.1",
        "@types/node": "^25.0.0",
        "@vitejs/plugin-basic-ssl": "^2.1.0",
        "typescript": "^5.9.0",
        "vite": "^7.3.0"
    },
    "trustedDependencies": [
        "@biomejs/biome",
        "@parcel/watcher",
        "esbuild"
    ]
}
