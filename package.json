{
    "name": "rose",
    "private": true,
    "type": "module",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "prepare": "bun run panda codegen",
        "dev": "vinxi dev --host 0.0.0.0 --port 5173",
        "dev:http": "ROSE_DEV_HTTPS=0 vinxi dev --host 127.0.0.1 --port 5173",
        "build": "vinxi build",
        "preview": "vinxi start --host 0.0.0.0",
        "check": "tsc",
        "lint": "biome check . && bun run --filter '@rose/*' format:check && bun run --filter '@rose/*' lint",
        "format": "biome format --write . && bun run --filter '@rose/*' format",
        "test": "bun test src packages",
        "test:rust": "bun run --filter '@rose/*-engine' test",
        "generate:wasm": "bun run --filter '@rose/*-engine' build",
        "generate:catalog": "bun run --filter @rose/weapon-catalog build",
        "audit:weapons": "bun run --filter @rose/weapon-catalog audit",
        "bench": "bun run --filter @rose/armor-bench bench",
        "verify": "bun run check && bun run lint && bun run test && bun run test:rust && bun run build",
        "hooks:install": "git config core.hooksPath .githooks",
        "version:bump": "bun scripts/bump-version.ts"
    },
    "dependencies": {
        "@rose/armor-domain": "workspace:*",
        "@rose/armor-engine": "workspace:*",
        "@rose/weapon-engine": "workspace:*",
        "@rose/weapon-model": "workspace:*",
        "@solid-primitives/event-listener": "^2.4.6",
        "@solid-primitives/scheduled": "^1.5.3",
        "@solid-primitives/storage": "^4.3.5",
        "@solidjs/router": "^0.16.1",
        "@solidjs/start": "^1.3.2",
        "bungie-api-ts": "^5.10.0",
        "idb-keyval": "^6.2.6",
        "lucide-solid": "^1.23.0",
        "solid-js": "^1.9.14"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.2",
        "@pandacss/dev": "^1.11.4",
        "@rose/armor-bench": "workspace:*",
        "@types/bun": "^1.3.14",
        "@types/node": "^26.1.0",
        "@vitejs/plugin-basic-ssl": "^2.3.0",
        "postcss": "^8.5.19",
        "typescript": "^6.0.3",
        "vinxi": "^0.5.11",
        "vite": "^6.4.3"
    },
    "packageManager": "bun@1.3.12",
    "trustedDependencies": [
        "@biomejs/biome",
        "@parcel/watcher",
        "esbuild"
    ]
}
