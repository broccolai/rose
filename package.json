{
    "name": "rose",
    "private": true,
    "type": "module",
    "scripts": {
        "predev": "bun run panda",
        "prebuild": "bun run panda",
        "dev": "bun x --bun vinxi dev --host 0.0.0.0 --port 5173",
        "dev:http": "ROSE_DEV_HTTPS=0 bun x --bun vinxi dev --host 127.0.0.1 --port 5173",
        "build": "bun x --bun vinxi build",
        "preview": "bun x --bun vinxi start --host 0.0.0.0",
        "postinstall": "bun run panda",
        "check": "bun x --bun tsc --noEmit",
        "lint": "bun run lint:web && bun run lint:rust",
        "lint:web": "bun x --bun biome check src functions packages app.config.ts panda.config.ts package.json tsconfig.json biome.json",
        "lint:rust": "cargo clippy --workspace --all-targets --all-features -- -D warnings",
        "format": "bun x --bun biome format --write src functions packages app.config.ts panda.config.ts package.json tsconfig.json biome.json",
        "panda": "bun x --bun panda codegen && bun x --bun panda cssgen \"src/**/*.{ts,tsx}\" -o src/app/styles/panda.css",
        "test": "bun test",
        "test:rust": "cargo test --workspace",
        "armor:wasm": "bun scripts/build-armor-wasm.ts",
        "test:bench": "bun test packages/armor-bench/src",
        "bench:d2ap": "bun packages/armor-bench/src/cli.ts",
        "bench:interactive-solve": "bun packages/armor-bench/src/interactive-solve-cli.ts",
        "bench:workloads": "bun packages/armor-bench/src/workload-cli.ts",
        "bench:slider-caps": "bun packages/armor-bench/src/slider-caps-cli.ts",
        "bench:rust": "bun packages/armor-bench/src/rust-wasm-cli.ts",
        "hooks:install": "git config core.hooksPath .githooks",
        "version:bump": "bun scripts/bump-version.ts"
    },
    "dependencies": {
        "@solid-primitives/event-listener": "^2.4.6",
        "@solid-primitives/scheduled": "^1.5.3",
        "@solid-primitives/storage": "^4.3.5",
        "@solidjs/router": "^0.16.1",
        "@solidjs/start": "^1.3.2",
        "bungie-api-ts": "^5.10.0",
        "idb-keyval": "^6.2.6",
        "lucide-solid": "^1.23.0",
        "solid-js": "^1.9.14"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.2",
        "@pandacss/dev": "^1.11.4",
        "@types/node": "^26.1.0",
        "@vitejs/plugin-basic-ssl": "^2.3.0",
        "typescript": "^6.0.3",
        "vinxi": "^0.5.11",
        "vite": "^8.1.3"
    },
    "trustedDependencies": [
        "@biomejs/biome",
        "@parcel/watcher",
        "esbuild"
    ]
}
