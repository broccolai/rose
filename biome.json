{
    "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 140
    },
    "files": {
        "includes": ["**", "!src/app/styles/panda.css"]
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "semicolons": "always",
            "trailingCommas": "none"
        }
    },
    "assist": {
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    },
    "linter": {
        "rules": {
            "complexity": {
                "useLiteralKeys": "off"
            }
        }
    }
}
