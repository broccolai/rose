{
    "compilerOptions": {
        "target": "ESNext",
        "lib": ["ESNext", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "jsx": "preserve",
        "jsxImportSource": "solid-js",
        "strict": true,
        "isolatedModules": true,
        "verbatimModuleSyntax": true,
        "moduleDetection": "force",
        "noUncheckedSideEffectImports": true,
        "exactOptionalPropertyTypes": true,
        "noImplicitReturns": true,
        "noPropertyAccessFromIndexSignature": true,
        "erasableSyntaxOnly": true,
        "skipLibCheck": true,
        "noEmit": true,
        "types": ["@solidjs/start/env", "vite/client", "node", "bun"],
        "paths": {
            "@/*": ["./src/*"],
            "@armor-domain": ["./packages/armor-domain/src/index.ts"],
            "@panda/*": ["./.panda/*"]
        }
    },
    "include": ["src", "functions", "packages", "scripts", "app.config.ts", "panda.config.ts"],
    "exclude": ["dist", ".panda", "node_modules", "tests", "**/*.test.ts", "**/*.test.tsx"]
}
